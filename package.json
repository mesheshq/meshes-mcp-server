{
  "name": "@mesheshq/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Meshes — emit events, manage workspaces, create rules, and inspect deliveries from any MCP-compatible client.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "@mesheshq/mcp-server": "dist/index.js",
    "meshes-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "meshes",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "webhooks",
    "integrations",
    "event-routing",
    "ai-tools",
    "cursor",
    "claude-code",
    "windsurf"
  ],
  "author": "Meshes Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mesheshq/meshes-mcp-server.git"
  },
  "homepage": "https://meshes.io/docs/ai/mcp-server",
  "bugs": {
    "url": "https://github.com/mesheshq/meshes-mcp-server/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "jose": "^6.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "4.0.18"
  }
}
